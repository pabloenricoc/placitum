generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(ADVOGADO)
  oab           String?
  escritorioId  String
  escritorio    Escritorio @relation(fields: [escritorioId], references: [id])
  prazos        Prazo[]   @relation("advogadoResponsavel")
  revisoes      Peca[]    @relation("revisadaPor")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([escritorioId])
}

enum UserRole {
  ADMIN
  ADVOGADO
  ESTAGIARIO
}

model Escritorio {
  id              String    @id @default(cuid())
  nome            String
  oabResponsavel  String?
  email           String
  plano           Plano     @default(STARTER)
  ativo           Boolean   @default(true)
  users           User[]
  processos       Processo[]
  fontesAtivas    FontePublicacao[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum Plano {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Processo {
  id              String    @id @default(cuid())
  escritorioId    String
  escritorio      Escritorio @relation(fields: [escritorioId], references: [id])
  numeroProcesso  String
  vara            String?
  comarca         String?
  areaDireito     AreaDireito
  parteCliente    String
  parteContraria  String?
  status          StatusProcesso @default(ATIVO)
  publicacoes     Publicacao[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([escritorioId, numeroProcesso])
  @@index([escritorioId])
  @@index([numeroProcesso])
}

enum AreaDireito {
  CIVEL
  TRABALHISTA
  PREVIDENCIARIO
  BANCARIO
  TRIBUTARIO
  OUTRO
}

enum StatusProcesso {
  ATIVO
  ARQUIVADO
  ENCERRADO
}

model Publicacao {
  id              String    @id @default(cuid())
  processoId      String?
  processo        Processo? @relation(fields: [processoId], references: [id])
  textoIntegral   String
  resumoIA        String?
  fonte           String
  dataPublicacao  DateTime
  dataCaptacao    DateTime  @default(now())
  statusAnalise   StatusAnalise @default(NOVA)
  confiancaIA     NivelConfianca?
  dadosExtraidos  Json?
  prazo           Prazo?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([processoId])
  @@index([statusAnalise])
  @@index([dataPublicacao])
}

enum StatusAnalise {
  NOVA
  EM_ANALISE
  ANALISADA
  PRAZO_CADASTRADO
  PECA_GERADA
  ERRO
}

enum NivelConfianca {
  ALTA
  MEDIA
  BAIXA
}

model Prazo {
  id                   String    @id @default(cuid())
  publicacaoId         String    @unique
  publicacao           Publicacao @relation(fields: [publicacaoId], references: [id])
  tipoProvidencia      TipoProvidencia
  descricaoProvidencia String?
  dataLimite           DateTime
  diasPrazo            Int
  tipoContagem         TipoContagem @default(UTEIS)
  status               StatusPrazo @default(PENDENTE)
  advResponsavelId     String?
  advResponsavel       User?     @relation("advogadoResponsavel", fields: [advResponsavelId], references: [id])
  peca                 Peca?
  notificacoes         Notificacao[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
  @@index([dataLimite])
  @@index([advResponsavelId])
}

enum TipoProvidencia {
  CONTESTACAO
  RECURSO_APELACAO
  RECURSO_AGRAVO
  EMBARGOS_DECLARACAO
  MANIFESTACAO
  IMPUGNACAO
  CONTRARRAZOES
  CUMPRIMENTO_SENTENCA
  OUTRO
}

enum TipoContagem {
  UTEIS
  CORRIDOS
}

enum StatusPrazo {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  VENCIDO
}

model Peca {
  id               String    @id @default(cuid())
  prazoId          String    @unique
  prazo            Prazo     @relation(fields: [prazoId], references: [id])
  tipoPeca         String
  conteudoRascunho String
  versao           Int       @default(1)
  status           StatusPeca @default(RASCUNHO)
  geradaPorIA      Boolean   @default(true)
  modeloIA         String?
  tokensInput      Int?
  tokensOutput     Int?
  revisadaPorId    String?
  revisadaPor      User?     @relation("revisadaPor", fields: [revisadaPorId], references: [id])
  revisadaEm       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

enum StatusPeca {
  RASCUNHO
  EM_REVISAO
  REVISADA
  APROVADA
  REJEITADA
}

model Notificacao {
  id        String    @id @default(cuid())
  prazoId   String
  prazo     Prazo     @relation(fields: [prazoId], references: [id])
  tipo      TipoNotificacao
  canal     CanalNotificacao @default(EMAIL)
  enviadaEm DateTime?
  status    StatusNotificacao @default(PENDENTE)
  erro      String?
  createdAt DateTime  @default(now())

  @@index([prazoId])
  @@index([status])
}

enum TipoNotificacao {
  TRES_DIAS
  UM_DIA
  HOJE
  VENCIDO
}

enum CanalNotificacao {
  EMAIL
  WHATSAPP
  PUSH
}

enum StatusNotificacao {
  PENDENTE
  ENVIADA
  FALHA
}

model RegraPrazo {
  id                String    @id @default(cuid())
  tipoPublicacao    String
  areaDireito       AreaDireito
  diasPrazo         Int
  tipoContagem      TipoContagem
  providenciaPadrao TipoProvidencia
  descricao         String?
  ativa             Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model TemplatePeca {
  id               String    @id @default(cuid())
  tipoProvidencia  TipoProvidencia
  areaDireito      AreaDireito
  nome             String
  conteudoTemplate String
  ativo            Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model FontePublicacao {
  id             String    @id @default(cuid())
  escritorioId   String
  escritorio     Escritorio @relation(fields: [escritorioId], references: [id])
  nome           String
  url            String
  ativa          Boolean   @default(true)
  ultimaCaptacao DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Feriado {
  id      String   @id @default(cuid())
  data    DateTime
  nome    String
  ambito  AmbitoFeriado @default(NACIONAL)
  estado  String?
  comarca String?
}

enum AmbitoFeriado {
  NACIONAL
  ESTADUAL
  MUNICIPAL
}
